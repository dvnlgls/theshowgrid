{"details": [{"n": "Capitani", "r": 6.9, "v": 822, "y": "2019", "ec": 13}], "ratings": [{"r": 7.4, "v": 48, "en": "Oh Du, do uewen", "eid": "tt10551616", "eno": 1, "sno": 1}, {"r": 7.4, "v": 39, "en": "A sengem donkle Bëscherkranz", "eid": "tt10551618", "eno": 2, "sno": 1}, {"r": 7.4, "v": 36, "en": "Aus der Kannerzäit, aus der Kannerzaït", "eid": "tt10551620", "eno": 3, "sno": 1}, {"r": 7.1, "v": 35, "en": "Kee Schlof méi fir d'Aen, kee Friden méi fir d'Hierz", "eid": "tt10551624", "eno": 4, "sno": 1}, {"r": 7.3, "v": 31, "en": "Déi Friem, déi mussen 't agestoen", "eid": "tt10551630", "eno": 5, "sno": 1}, {"r": 7.5, "v": 27, "en": "Souwäit vu mir, sou waït!", "eid": "tt10551634", "eno": 6, "sno": 1}, {"r": 7.5, "v": 26, "en": "AN ech weess vun Tréin a Leed", "eid": "tt10551638", "eno": 7, "sno": 1}, {"r": 7.5, "v": 24, "en": "A wéi schéin déi gëllen Dreem", "eid": "tt10551642", "eno": 8, "sno": 1}, {"r": 7.8, "v": 22, "en": "Voll Vertraue wor mäin Hierz", "eid": "tt10552088", "eno": 9, "sno": 1}, {"r": 8.0, "v": 24, "en": "Ech wousst näischt vun Tréin a Schmierz", "eid": "tt10552100", "eno": 10, "sno": 1}, {"r": 7.5, "v": 23, "en": "An d'Broscht voll däischter Nuecht", "eid": "tt10552116", "eno": 11, "sno": 1}, {"r": 8.2, "v": 27, "en": "Et wor op engem schéinen klore Summerdag", "eid": "tt10552134", "eno": 12, "sno": 1}]}
