{"details": [{"n": "The Ambassador's Daughter", "r": 6.2, "v": 1175, "y": "2019", "ec": 33}], "ratings": [{"r": 8.5, "v": 96, "en": "1.Bölüm", "eid": "tt11399038", "eno": 1, "sno": 1}, {"r": 8.5, "v": 69, "en": "Efem ala boyanmis, kaniyor her yani.", "eid": "tt11444058", "eno": 2, "sno": 1}, {"r": 8.5, "v": 66, "en": "Adini anmayacagima Nasuh Tövbesi olsun mu?", "eid": "tt11444060", "eno": 3, "sno": 1}, {"r": 8.7, "v": 54, "en": "Bana memleket olmadin, kizima ol.", "eid": "tt11528728", "eno": 4, "sno": 1}, {"r": 8.6, "v": 49, "en": "Biz o enkazin altinda kaldik.", "eid": "tt11611104", "eno": 5, "sno": 1}, {"r": 8.7, "v": 47, "en": "Ben sana suçluyken bile inandim.", "eid": "tt11650138", "eno": 6, "sno": 1}, {"r": 8.3, "v": 45, "en": "Arkadaslar uykularda uyansin.", "eid": "tt11690056", "eno": 7, "sno": 1}, {"r": 8.5, "v": 43, "en": "Bana niye mektup yazmadin?", "eid": "tt11728420", "eno": 8, "sno": 1}, {"r": 8.5, "v": 43, "en": "Kimse sana inanmak istemez.", "eid": "tt11771060", "eno": 9, "sno": 1}, {"r": 8.5, "v": 43, "en": "Sen mi bana kiydin, ben mi sana kiydim?", "eid": "tt11812628", "eno": 10, "sno": 1}, {"r": 8.6, "v": 44, "en": "Delirme, delirince geçmiyor.", "eid": "tt11854000", "eno": 11, "sno": 1}, {"r": 8.7, "v": 40, "en": "Uzun ince bir yoldayim", "eid": "tt11902936", "eno": 12, "sno": 1}, {"r": 8.3, "v": 38, "en": "Ben senin katilin olmusum", "eid": "tt11945354", "eno": 13, "sno": 1}, {"r": 8.3, "v": 36, "en": "Kizinin elinden tut", "eid": "tt11981198", "eno": 14, "sno": 1}, {"r": 8.3, "v": 41, "en": "Öfkeli bir çocuga daha fazla eyvallahim yok", "eid": "tt12038320", "eno": 15, "sno": 1}, {"r": 8.4, "v": 37, "en": "Sen gidersen ben çok kötü bir adam olurum.", "eid": "tt12476282", "eno": 16, "sno": 1}, {"r": 8.4, "v": 39, "en": "Bu destan denizin dibinde basladi, orada bitmez ki.", "eid": "tt12528906", "eno": 17, "sno": 1}, {"r": 8.1, "v": 34, "en": "Sana canimi veririm, adini vermem.", "eid": "tt13010822", "eno": 1, "sno": 2}, {"r": 8.3, "v": 27, "en": "Senin yaninda yara mi olacak, benim yaninda yar mi?", "eid": "tt13051948", "eno": 2, "sno": 2}, {"r": 8.2, "v": 27, "en": "Ben ganimet degilim.", "eid": "tt13093964", "eno": 3, "sno": 2}, {"r": 8.5, "v": 24, "en": "Bana kizim yeter.", "eid": "tt13142350", "eno": 4, "sno": 2}, {"r": 8.6, "v": 25, "en": "Sensizlik yakiyor, onsuzluk öldürür.", "eid": "tt13229002", "eno": 5, "sno": 2}, {"r": 8.5, "v": 23, "en": "Helalim sensin benim.", "eid": "tt13229024", "eno": 6, "sno": 2}, {"r": 8.2, "v": 24, "en": "Senin acin, senin hakkin.", "eid": "tt13269462", "eno": 7, "sno": 2}, {"r": 8.2, "v": 25, "en": "Destanlarda kavusamazsin ama asla ayrilmazsin.", "eid": "tt13327528", "eno": 8, "sno": 2}, {"r": 7.8, "v": 20, "en": "Alacakus olan bendim, sen niye uçtun?", "eid": "tt13376564", "eno": 9, "sno": 2}, {"r": 8.3, "v": 17, "en": "Yolun sonunda sen varsin.", "eid": "tt13403060", "eno": 10, "sno": 2}, {"r": 8.9, "v": 7, "en": "Baba omzu diye bir yer var.", "eid": "tt13450512", "eno": 11, "sno": 2}, {"r": 9.3, "v": 7, "en": "Allah'im emri, peygamberin kavliyle...", "eid": "tt13508578", "eno": 12, "sno": 2}, {"r": 8.6, "v": 8, "en": "Benim memleketim yarasinda çiçek açtirir.", "eid": "tt13546380", "eno": 13, "sno": 2}, {"r": 8.0, "v": 8, "en": "Beni yakmamayi ögrenecek misin?", "eid": "tt13587102", "eno": 14, "sno": 2}]}
