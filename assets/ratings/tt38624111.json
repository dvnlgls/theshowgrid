{"details": [{"n": "Domenica Montero", "r": 7.2, "v": 106, "y": "2025", "ec": 50}], "ratings": [{"r": 5.5, "v": 19, "en": "¿Quieres ser mi esposa?", "eid": "tt38841088", "eno": 1, "sno": 1}, {"r": 4.7, "v": 14, "en": "¡Lárguense de mi casa!", "eid": "tt39147748", "eno": 2, "sno": 1}, {"r": 4.0, "v": 12, "en": "Estas son mis tierras", "eid": "tt39147749", "eno": 3, "sno": 1}, {"r": 4.3, "v": 13, "en": "Nada justifica un alma negra", "eid": "tt39147751", "eno": 5, "sno": 1}, {"r": 4.5, "v": 13, "en": "Una tierra sin ley", "eid": "tt39147752", "eno": 4, "sno": 1}, {"r": 4.0, "v": 12, "en": "Los chismes no corren, vuelan", "eid": "tt39147753", "eno": 6, "sno": 1}, {"r": 3.8, "v": 13, "en": "El bebé no sobrevivió", "eid": "tt39147754", "eno": 7, "sno": 1}, {"r": 4.0, "v": 12, "en": "Conozco mis derechos", "eid": "tt39147755", "eno": 9, "sno": 1}, {"r": 4.0, "v": 12, "en": "Me pareces un héroe", "eid": "tt39147756", "eno": 8, "sno": 1}, {"r": 4.0, "v": 12, "en": "Yo no confío en nadie", "eid": "tt39147757", "eno": 10, "sno": 1}, {"r": 3.5, "v": 11, "en": "Ya no soy Pedro Nadie", "eid": "tt39147758", "eno": 11, "sno": 1}, {"r": 3.5, "v": 11, "en": "Del odio al amor hay un paso", "eid": "tt39164268", "eno": 12, "sno": 1}, {"r": 3.5, "v": 11, "en": "La verdad no peca, pero bien que incomoda", "eid": "tt39197401", "eno": 13, "sno": 1}, {"r": 3.5, "v": 11, "en": "Actuaste a mis espaldas", "eid": "tt39197403", "eno": 14, "sno": 1}, {"r": 2.7, "v": 10, "en": "No me meteré entre ustedes", "eid": "tt39197404", "eno": 16, "sno": 1}, {"r": 2.0, "v": 9, "en": "No puedo confiar en los hombres", "eid": "tt39197405", "eno": 15, "sno": 1}, {"r": 2.0, "v": 9, "en": "Él juega al mejor postor", "eid": "tt39197407", "eno": 17, "sno": 1}, {"r": 2.0, "v": 9, "en": "Por favor, no me traiciones", "eid": "tt39197408", "eno": 18, "sno": 1}, {"r": 2.0, "v": 9, "en": "Aprendí a odiar", "eid": "tt39197409", "eno": 19, "sno": 1}, {"r": 2.8, "v": 10, "en": "Pedro merece una familia", "eid": "tt39197410", "eno": 20, "sno": 1}, {"r": 2.0, "v": 9, "en": "¿Desde cuando lo sabías?", "eid": "tt39197411", "eno": 21, "sno": 1}, {"r": 2.0, "v": 9, "en": "Todo en esta vida se paga", "eid": "tt39316451", "eno": 22, "sno": 1}, {"r": 2.0, "v": 9, "en": "No es mujer para ti", "eid": "tt39320358", "eno": 23, "sno": 1}, {"r": 2.8, "v": 10, "en": "Esto fue un sabotaje", "eid": "tt39320359", "eno": 24, "sno": 1}, {"r": 2.7, "v": 10, "en": "El odio transforma a las personas", "eid": "tt39320360", "eno": 25, "sno": 1}, {"r": 2.0, "v": 9, "en": "Nunca quise lastimarte", "eid": "tt39320361", "eno": 26, "sno": 1}, {"r": 2.0, "v": 9, "en": "Me usaste para olvidarlo", "eid": "tt39320362", "eno": 27, "sno": 1}, {"r": 2.0, "v": 9, "en": "Un pacto con el diablo", "eid": "tt39320363", "eno": 29, "sno": 1}, {"r": 2.0, "v": 9, "en": "Lo nuestro es para siempre", "eid": "tt39320364", "eno": 28, "sno": 1}, {"r": 2.0, "v": 9, "en": "Iba a luchar por ti", "eid": "tt39320365", "eno": 30, "sno": 1}, {"r": 2.8, "v": 10, "en": "¿Qué haces con mi anillo de compromiso?", "eid": "tt39386493", "eno": 31, "sno": 1}, {"r": 2.0, "v": 9, "en": "Te perdono", "eid": "tt39389759", "eno": 32, "sno": 1}, {"r": 2.0, "v": 9, "en": "¿Quieres casarte conmigo?", "eid": "tt39391718", "eno": 33, "sno": 1}, {"r": 2.8, "v": 10, "en": "¡Esta mujer te está estafando!", "eid": "tt39393277", "eno": 34, "sno": 1}, {"r": 2.0, "v": 9, "en": "Estas tierras son más mías que de nadie", "eid": "tt39397214", "eno": 36, "sno": 1}, {"r": 2.6, "v": 10, "en": "Nos vemos en el tribunal", "eid": "tt39397215", "eno": 35, "sno": 1}, {"r": 2.0, "v": 9, "en": "Episode #1.37", "eid": "tt39397217", "eno": 37, "sno": 1}, {"r": 2.8, "v": 10, "en": "Episode #1.38", "eid": "tt39397218", "eno": 38, "sno": 1}, {"r": 2.0, "v": 9, "en": "Episode #1.39", "eid": "tt39397219", "eno": 39, "sno": 1}, {"r": 2.8, "v": 10, "en": "Episode #1.40", "eid": "tt39397220", "eno": 40, "sno": 1}, {"r": 2.0, "v": 9, "en": "Episode #1.41", "eid": "tt39674676", "eno": 41, "